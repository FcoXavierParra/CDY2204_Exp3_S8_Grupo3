# =============================================================
#  Variables de entorno - copia este archivo a .env y completa
#  (.env NO se sube a git; ver .gitignore)
# =============================================================

# --- Azure AD B2C (IDaaS) ---
AZURE_ISSUER_URI=https://login.microsoftonline.com/<TU_TENANT_ID>/v2.0
AZURE_JWKS_URI=https://<TU_TENANT>.b2clogin.com/<TU_TENANT_ID>/discovery/v2.0/keys
AZURE_AUDIENCE=<TU_APPLICATION_CLIENT_ID>
AZURE_ROLE_CLAIM=extension_rol

# --- AWS S3 ---
AWS_S3_BUCKET=<TU_BUCKET_S3>
AWS_S3_REGION=us-east-1

# --- Credenciales AWS Academy (se refrescan en cada Start Lab) ---
AWS_ACCESS_KEY_ID=<TU_ACCESS_KEY>
AWS_SECRET_ACCESS_KEY=<TU_SECRET_KEY>
AWS_SESSION_TOKEN=<TU_SESSION_TOKEN>

# --- Oracle Cloud (Autonomous Database) ---
# El wallet descomprimido va en ./wallet (ignorado por git). En docker-compose
# se monta en /app/wallet. El alias TNS sale de tnsnames.ora dentro del wallet.
ORACLE_TNS_ALIAS=oraclecloudfparradb_tp
ORACLE_USER=ADMIN
ORACLE_PASSWORD=<PASSWORD_DEL_USUARIO_ADMIN>
# (Opcional) URL JDBC completa; en local por defecto usa ./wallet
# ORACLE_JDBC_URL=jdbc:oracle:thin:@oraclecloudfparradb_tp?TNS_ADMIN=./wallet

# --- RabbitMQ ---
# En local con docker-compose no hace falta tocar nada (localhost/guest/guest).
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
